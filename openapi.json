  "components": {
    "schemas": {
      "ClavePregunta": {
        "type": "string",
        "enum": [
          "que_producto_te_gustaria_que_sumemos",
          "que_parte_de_panacea_es_tu_favorita",
          "de_donde_son"
        ],
        "title": "ClavePregunta"
      },
      "DetalleCreate": {
        "properties": {
          "producto_id": {
            "type": "string",
            "maxLength": 100,
            "title": "Producto Id",
            "examples": [
              "CERVEZA-IPA-500ML"
            ]
          },
          "cantidad": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Cantidad",
            "examples": [
              2
            ]
          },
          "subtotal": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "string"
              }
            ],
            "title": "Subtotal",
            "examples": [
              [
                "350.00"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "producto_id",
          "cantidad",
          "subtotal"
        ],
        "title": "DetalleCreate"
      },
      "DetalleResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "registro_venta_id": {
            "type": "integer",
            "title": "Registro Venta Id"
          },
          "producto_id": {
            "type": "string",
            "title": "Producto Id"
          },
          "cantidad": {
            "type": "integer",
            "title": "Cantidad"
          },
          "subtotal": {
            "type": "string",
            "title": "Subtotal"
          }
        },
        "type": "object",
        "required": [
          "id",
          "registro_venta_id",
          "producto_id",
          "cantidad",
          "subtotal"
        ],
        "title": "DetalleResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PreguntaCreate": {
        "properties": {
          "clave": {
            "$ref": "#/components/schemas/ClavePregunta",
            "examples": [
              "que_producto_te_gustaria_que_sumemos"
            ]
          },
          "valor": {
            "type": "string",
            "minLength": 1,
            "title": "Valor",
            "examples": [
              "Cervezas artesanales"
            ]
          }
        },
        "type": "object",
        "required": [
          "clave",
          "valor"
        ],
        "title": "PreguntaCreate"
      },
      "PreguntaResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "socio_id": {
            "type": "integer",
            "title": "Socio Id"
          },
          "clave": {
            "$ref": "#/components/schemas/ClavePregunta"
          },
          "valor": {
            "type": "string",
            "title": "Valor"
          }
        },
        "type": "object",
        "required": [
          "id",
          "socio_id",
          "clave",
          "valor"
        ],
        "title": "PreguntaResponse"
      },
      "PreguntaUpdate": {
        "properties": {
          "valor": {
            "type": "string",
            "minLength": 1,
            "title": "Valor"
          }
        },
        "type": "object",
        "required": [
          "valor"
        ],
        "title": "PreguntaUpdate"
      },
      "SocioCreate": {
        "properties": {
          "nombre_apellido": {
            "type": "string",
            "maxLength": 200,
            "title": "Nombre Apellido",
            "examples": [
              "Juan P\u00e9rez"
            ]
          },
          "telefono": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 30
              },
              {
                "type": "null"
              }
            ],
            "title": "Telefono",
            "examples": [
              "+54 9 11 1234-5678"
            ]
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email",
            "examples": [
              "juan@example.com"
            ]
          },
          "fecha_nacimiento": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fecha Nacimiento",
            "examples": [
              "1990-05-15"
            ]
          },
          "dni": {
            "type": "string",
            "maxLength": 20,
            "title": "Dni",
            "examples": [
              "30123456"
            ]
          }
        },
        "type": "object",
        "required": [
          "nombre_apellido",
          "email",
