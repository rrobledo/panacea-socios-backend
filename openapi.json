              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SocioResponse"
                  },
                  "title": "Response List Socios Socios  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Socios"
        ],
        "summary": "Crear socio",
        "description": "Crea un nuevo socio. DNI y email deben ser \u00fanicos.",
        "operationId": "create_socio_socios__post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
