{
  "openapi": "3.1.0",
  "info": {
    "title": "Panacea Socios API",
    "description": "API para gesti\u00f3n de socios, sus preferencias y registro de ventas de Panacea. Permite registrar clientes, capturar sus respuestas a preguntas clave y llevar un historial de compras para futuras promociones y regalos.",
    "contact": {
      "name": "Panacea",
      "email": "info@panacea.com"
    },
    "license": {
      "name": "Proprietary"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/socios/": {
      "get": {
        "tags": [
          "Socios"
        ],
        "summary": "Listar socios",
        "description": "Retorna la lista paginada de socios. Filtra por `dni` (exacto) y/o `name` (parcial, sin distinci\u00f3n de may\u00fasculas).",
        "operationId": "list_socios_socios__get",
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Skip"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "title": "Limit"
            }
          },
          {
            "name": "dni",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Dni"
            }
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
